# ─── Supabase ────────────────────────────────────────────────────────────────
# Painel do projeto Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua_anon_key_aqui"
# Service role key: usada SOMENTE no servidor (criar usuários, operações admin).
# Obrigatória para ativar/desativar logins em /pessoas.
SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key_aqui"

# ─── Sync VIOS (vios-app no servidor) — dual-write para este projeto ─────────
# Configure no .env do vios-app, não necessariamente aqui no Next.js:
# SAMA_SUPABASE_URL="https://SEU-PROJETO-SAMA.supabase.co"
# SAMA_SUPABASE_SERVICE_ROLE_KEY="service_role_do_SAMA"
# VIOS_USER="seu_usuario@vios.com.br"
# VIOS_PASS="sua_senha_vios"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Microsoft Graph (Outlook) — app-only (client credentials) ───────────────
# Registre/reaproveite um app no Azure AD (ex.: Legis-app).
MICROSOFT_TENANT_ID=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
# Aliases legados (opcionais — graph.ts aceita estes nomes também):
# SHAREPOINT_CLIENT_ID=""
# SHAREPOINT_CLIENT_SECRET=""
